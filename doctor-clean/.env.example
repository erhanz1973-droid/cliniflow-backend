# doctor-clean — public env (Expo / EAS)
# Setup: copy this file to `.env` in this folder (gitignored) and fill the anon key.
# EAS: add the same `EXPO_PUBLIC_*` variables as project Secrets for preview/production builds.

# Optional — defaults to cliniflow-app production Railway API if unset
# EXPO_PUBLIC_API_URL=https://cliniflow-backend-clean-production.up.railway.app

# Public project URL (matches production backend Supabase project)
EXPO_PUBLIC_SUPABASE_URL=https://swxinrwbylygoqdcbwbt.supabase.co

# Required for `getSupabaseClient()` / RLS client: Supabase Dashboard → Project Settings → API → anon public
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# EAS: use `eas secret:create` or dashboard; `extra.eas.projectId` comes from `eas init` in app.json
