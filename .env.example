SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
ADMIN_JWT_SECRET=
# JWT lifetime for patient/admin tokens (e.g. 7d, 30d, 90d). Default 30d.
JWT_EXPIRES_IN=30d
# Optional: comma-separated browser origins when tightening CORS (mobile apps often send no Origin — still allowed).
# CORS_ORIGINS=https://your-admin.netlify.app,https://app.example.com
SUPABASE_STORAGE_BUCKET=patient-files
ROBOFLOW_API_KEY=

# ── App Config ────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_ENV=production

# ── Core AI ───────────────────────────────────────────────────────────────────
# Required: GPT-4o Vision for dental photo analysis
OPENAI_API_KEY=

# Optional: Replicate GFPGAN face/dental enhancement
REPLICATE_API_TOKEN=

# ── Image Processing ──────────────────────────────────────────────────────────
# Max upload size for images (MB). Applies to /api/chat/upload and /api/chat/ai-analyze
IMAGE_MAX_SIZE_MB=5
# Timeout (ms) for OpenAI + Replicate calls
AI_TIMEOUT_MS=15000

# ── Location ──────────────────────────────────────────────────────────────────
# Optional: used as fallback when Google Maps URL cannot be parsed for coordinates
# Get a key at https://console.cloud.google.com → Geocoding API
GOOGLE_GEOCODING_API_KEY=

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "false" to disable individual features without removing env vars
ENABLE_AI_ANALYSIS=true
ENABLE_SMILE_SIMULATION=true
ENABLE_MULTI_PHOTO_PROGRESS=true

# ── Smile simulation debug (local) ───────────────────────────────────────────
# SIM_SMILE_DEBUG_BLACK=1 → black JPEG from cropCompositeSimulation (routing test). Unset when done.

# ── Expo app (cliniflow-app) ─────────────────────────────────────────────────
# Local API URL for the patient app: copy cliniflow-app/.env.example → cliniflow-app/.env
# EXPO_PUBLIC_API_BASE=http://<LAN-IP>:<port>  (not localhost on a physical device)

# ── Railway backend (cliniflow-backend-clean) push diagnostics ───────────────
# DOCTOR_PUSH_EXPO_TRACE=1 → [DOCTOR_PUSH_SEND] / [DOCTOR_PUSH_RECEIPT] for doctor Expo (tokens redacted, getReceipts after send).
# DOCTOR_PUSH_NO_TOKEN_LOG=1 → always log expanded no_expo_tokens probe (push_tokens row count for doctor id) even if trace off.
# EXPO_PUSH_RECEIPT_PRUNE=1 → without trace: still fetch receipts and delete invalid Expo tokens from DB (DeviceNotRegistered, etc.).
# CHAT_PUSH_ROUTING_LOG=1 → extra [CHAT_PUSH_ROUTING] for patient_inbound when push would send.
# PATIENT_PUSH_PAYLOAD_LOG=1 or EXPO_PUSH_DEBUG_LOGS=1 → patient payload / batch preview logs.

# doctor-clean (Expo): EXPO_PUBLIC_DOCTOR_PUSH_DELIVERY_LOG=1, EXPO_PUBLIC_DOCTOR_PUSH_RESYNC_ON_ACTIVE=1 (foreground token re-sync, throttled).
