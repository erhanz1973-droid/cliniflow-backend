# Backend URL for the standalone admin (set in HTML, not from this file in the browser).
#
# Hosted at https://cliniflow-admin.onrender.com → api-base.js already defaults to:
#   https://cliniflow-backend-dg8a.onrender.com
#
# Custom admin domain or different backend → before api-base.js add either:
#   <meta name="cliniflow-api-base" content="https://your-api.onrender.com" />
#   <script>window.CLINIFLOW_API_BASE_URL="https://your-api.onrender.com"</script>
#
# Local dev: api-base.js uses http://localhost:10000 (or 127.0.0.1:10000).
#
# If admin HTML is served from the backend host but API calls go to this service
# (cliniflow-admin.onrender.com), JWT_SECRET must match the backend service exactly
# or Bearer tokens from /api/admin/login will get 401 on this API.

CLINIFLOW_API_BASE_URL=https://cliniflow-backend-dg8a.onrender.com
JWT_SECRET=use-the-same-value-as-cliniflow-backend-render-service
